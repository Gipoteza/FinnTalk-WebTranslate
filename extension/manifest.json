{
  "manifest_version": 3,
  "name": "Finnish to Russian Translator",
  "version": "1.0.2",
  "description": "Автоматический перевод финских веб-страниц на русский язык через ChatGPT API",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://finntalk-webtranslate-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.fi/*",
        "https://*.fi",
        "http://*.fi/*",
        "http://*.fi"
      ],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Finnish Translator",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options/options.html"
}
