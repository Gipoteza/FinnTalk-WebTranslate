{
  "name": "finnish-to-russian-translator",
  "version": "1.0.2",
  "description": "Браузерное расширение для перевода финских страниц на русский язык через ChatGPT API",
  "private": true,
  "scripts": {
    "build": "node build.js",
    "test": "jest --runInBand",
    "test:run": "jest --runInBand --forceExit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/jest": "^29.5.12",
    "esbuild": "^0.28.0",
    "fast-check": "^3.19.0",
    "jest": "^29.7.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "./tsconfig.test.json"
        }
      ]
    }
  }
}
